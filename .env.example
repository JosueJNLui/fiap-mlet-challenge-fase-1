# Copie para .env (cp .env.example .env) e preencha com seu usuário e token DagsHub.
# .env já está no .gitignore — não commite o arquivo preenchido.

# ─── Autenticação DagsHub (OBRIGATÓRIO) ───────────────────────────────────────
# Username é o seu nome de usuário no DagsHub (não necessariamente JosueJNLui).
MLFLOW_TRACKING_USERNAME=seu-username-no-dagshub
# Token gerado em: https://dagshub.com/user/settings/tokens
MLFLOW_TRACKING_PASSWORD=seu-default-access-token-no-dagshub

# ─── MLflow / Modelo (defaults sensatos — ajuste se necessário) ──────────────
MLFLOW_TRACKING_URI=https://dagshub.com/JosueJNLui/fiap-mlet-challenge-fase-1.mlflow
MODEL_FLAVOR=sklearn                       # sklearn | pytorch
MODEL_NAME=Churn_LogReg_Final_Production
# A partir da Etapa 3, o flavor sklearn registra a Pipeline empacotada
# (FeatureEngineer + StandardScaler + LogReg) como artefato único. Ajuste
# MODEL_VERSION para a versão produzida pela reexecução de modeling.ipynb
# (célula "Pipeline de produção (LogReg) — Etapa 3"). O alias @production é
# movido automaticamente pela própria célula.
MODEL_VERSION=3
# SCALER_ARTIFACT_PATH só é usado no flavor pytorch (MLP). No flavor sklearn,
# o scaler vive dentro da Pipeline e este path é ignorado.
SCALER_ARTIFACT_PATH=model_components/scaler.joblib
PREDICTION_THRESHOLD=0.2080

# ─── Fallback A/B-testável: MLP (PyTorch) ────────────────────────────────────
# Para servir o MLP em vez da LogReg, comente os 4 acima e descomente:
# MODEL_FLAVOR=pytorch
# MODEL_NAME=Churn_MLP_Final_Production
# MODEL_VERSION=8
# PREDICTION_THRESHOLD=0.20303030303030303

# ─── Dev / Debug ─────────────────────────────────────────────────────────────
# Defina como false para subir a API sem carregar o modelo (apenas /health funciona).
LOAD_MODEL_ON_STARTUP=true

# ─── Documentação OpenAPI / Swagger ──────────────────────────────────────────
# Defina vazio (ex.: DOCS_URL=) para desabilitar a UI em produção.
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
